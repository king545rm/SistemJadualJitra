# ASTS Environment Variables — copy this file to .env and fill in your values
# DO NOT commit the real .env file!

# Supabase PostgreSQL connection (via connection pooler, port 6543)
# Format: postgresql://postgres.{PROJECT_REF}:{URL_ENCODED_PASSWORD}@aws-0-{REGION}.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Find these in: Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Session signing secret (HMAC) — generate a random 32+ char string
# Run: openssl rand -hex 32
SESSION_SECRET="generate-a-random-32-char-secret-here!"
