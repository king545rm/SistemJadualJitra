// CAOMS — CKT Adik Order Management System
// Prisma schema (Supabase PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Authentication & RBAC ----------
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  passwordHash        String
  role                String    // PEMILIK | KAUNTER | DAPUR
  isDummy             Boolean   @default(true)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  auditLogs AuditLog[]
  pesanan   Pesanan[]

  @@index([role])
}

// ---------- Master Data ----------
model Menu {
  id          String   @id @default(cuid())
  nama        String
  kod         String   @unique
  kategori    String   // MEE_KUEY_TEOW | NASI | MINUMAN | SNEK | TAMBAHAN
  harga       Float
  deskripsi   String?
  tersedia    Boolean  @default(true)
  isDummy     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([kategori])
  @@index([tersedia])
}

model Pelanggan {
  id          String   @id @default(cuid())
  nama        String
  telefon     String   @unique
  catatan     String?
  isDummy     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pesanan Pesanan[]

  @@index([telefon])
}

// ---------- Orders ----------
model Pesanan {
  id            String    @id @default(cuid())
  noPesanan     String    @unique // auto-generated: ORD-001, ORD-002...
  jenis         String    // DINE_IN | BUNGKUS | DELIVERY
  mejaNama      String?   // table number or customer name
  pelangganId   String?
  status        String    @default("DITERIMA") // DITERIMA | DIMASAK | SIAP | DIAMBIL | DIBATALKAN
  jumlah        Float     @default(0)
  jumlahDibayar Float     @default(0)
  baki          Float     @default(0)
  catatan       String?
  waktuPesanan  DateTime  @default(now())
  waktuSiap     DateTime?
  waktuAmbil    DateTime?
  diambilOleh   String?   // user id who took the order
  isDummy       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pelanggan Pelanggan? @relation(fields: [pelangganId], references: [id])
  user      User?      @relation(fields: [diambilOleh], references: [id])
  items     OrderItem[]

  @@index([status])
  @@index([waktuPesanan])
  @@index([jenis])
}

model OrderItem {
  id          String   @id @default(cuid())
  pesananId   String
  menuId      String
  namaSewaktu String   // snapshot of menu name at order time
  hargaSewaktu Float   // snapshot of price
  kuantiti    Int      @default(1)
  opsyen      String?  // JSON: { addOns: [], customizations: "" }
  nota        String?  // e.g. "tak nak taugeh", "pedas"
  subtotal    Float
  createdAt   DateTime @default(now())

  pesanan Pesanan @relation(fields: [pesananId], references: [id], onDelete: Cascade)
  menu    Menu    @relation(fields: [menuId], references: [id])

  @@index([pesananId])
  @@index([menuId])
}

// ---------- Governance ----------
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String
  userRole  String?
  action    String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | LOGIN_FAILED | STATUS_UPDATE | CANCEL
  entity    String   // PESANAN | MENU | PELANGGAN | USER | etc.
  entityId  String?
  before    String?
  after     String?
  ipAddress String?
  timestamp DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([timestamp])
}
